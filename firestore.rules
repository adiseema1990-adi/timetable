rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is valid (alphanumeric, dash, underscore, spaces, and brackets allowed)
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 100 && id.matches('^[a-zA-Z0-9_\\-\\s\\(\\)\\[\\]\\.,]+$');
    }

    // Entity validation blueprint for timetable
    function isValidTimetable(data) {
      return data.name is string 
        && data.name.size() > 0 
        && data.name.size() <= 100
        && data.updatedAt is string
        && data.userId is string
        && data.userId.size() > 0
        && data.faculties is list
        && data.subjects is list
        && data.classes is list
        && data.assignments is list
        && data.timeSlots is list
        && data.days is list;
    }

    function isSuperuser() {
      return request.auth != null && request.auth.token.email == "sachinadi88@gmail.com";
    }

    function isAuthorizedMember() {
      return request.auth != null 
        && request.auth.token.email_verified == true 
        && request.auth.token.email in [
             'adiseema1990@gmail.com', 
             'sachinadi88@gmail.com', 
             'another.teacher@gmail.com'
           ];
    }

    match /mvce_timetables/{timetableId} {
      allow read: if isAuthorizedMember() && (isSuperuser() || resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthorizedMember()
                    && isValidId(timetableId) 
                    && isValidTimetable(request.resource.data)
                    && (isSuperuser() || request.resource.data.userId == request.auth.uid);
      allow update: if isAuthorizedMember()
                    && isValidId(timetableId) 
                    && isValidTimetable(request.resource.data)
                    && (isSuperuser() || (request.resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId));
      allow delete: if isAuthorizedMember()
                    && isValidId(timetableId)
                    && (isSuperuser() || resource.data.userId == request.auth.uid);
    }
  }
}
